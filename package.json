{
  "name": "perrenials",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A field guide and yard visualizer for permaculture perennials — search plants by bloom, light, moisture, function, and use.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "minisearch": "^7.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1"
  }
}
